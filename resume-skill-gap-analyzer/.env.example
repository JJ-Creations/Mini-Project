# GitHub Token (optional, increases API rate limit from 60 to 5000 req/hr)
# Get token at: https://github.com/settings/tokens (scope: public_repo)
GITHUB_TOKEN=

# Groq API Key for LLM-powered analysis (required for AI features)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=

# Serper API Key for live learning resource links via Google Search (optional)
# Get your key at: https://serper.dev
SERPER_API_KEY=

# CORS origins (comma-separated, or "*" for all; defaults to Railway + localhost)
# CORS_ORIGINS=https://yourdomain.com,http://localhost:5173

# Port (used by Docker/Railway; defaults to 8000)
# PORT=8000
